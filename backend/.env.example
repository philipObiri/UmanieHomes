# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Leave blank in development to use SQLite (default).
# Set this for PostgreSQL locally or in production:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/realestate_erp
DATABASE_URL=

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email (Mailtrap for dev/staging, your SMTP provider for production)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_HOST_USER=your-mailtrap-username
EMAIL_HOST_PASSWORD=your-mailtrap-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Media / File Storage
# Development: files stored on disk (USE_S3=False)
# Production: set USE_S3=True and fill in DigitalOcean Spaces credentials below
MEDIA_ROOT=media/
MEDIA_URL=/media/

# S3-compatible storage (DigitalOcean Spaces or AWS S3)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=umanie-media
# DigitalOcean Spaces endpoint — change region (nyc3/ams3/sgp1) as needed
AWS_S3_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com
AWS_S3_REGION_NAME=nyc3

# CORS (production: list your frontend domain)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Platform
PLATFORM_DOMAIN=localhost:8000

# WhatsApp (Meta Business API — leave blank until ready)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Twilio SMS — leave blank until ready
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
